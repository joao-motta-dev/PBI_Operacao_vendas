expression fnRemoverAcentos = ```
		(texto as any) =>
		let
		    // Verifica se o valor é nulo para evitar erros
		    txt = if texto = null then "" else Text.From(texto),
		    
		    // Listas expandidas
		    comAcento = {"á","à","â","ã","ä","é","è","ê","ë","í","ì","î","ï","ó","ò","ô","õ","ö","ú","ù","û","ü","ç","Á","À","Â","Ã","Ä","É","È","Ê","Ë","Í","Ì","Î","Ï","Ó","Ò","Ô","Õ","Ö","Ú","Ù","Û","Ü","Ç"},
		    semAcento = {"a","a","a","a","a","e","e","e","e","i","i","i","i","o","o","o","o","o","u","u","u","u","c","A","A","A","A","A","E","E","E","E","I","I","I","I","O","O","O","O","O","U","U","U","U","C"},
		    
		    // Transforma as listas em um formato de "De/Para"
		    pares = List.Zip({comAcento, semAcento}),
		    
		    // O segredo: List.Accumulate percorre a palavra e troca cada letra encontrada
		    resultado = List.Accumulate(pares, txt, (estado, atual) => Text.Replace(estado, atual{0}, atual{1}))
		in
		    resultado
		```
	lineageTag: 85304f78-f16c-41c4-9915-f2366c4123a3
	queryGroup: Prata

