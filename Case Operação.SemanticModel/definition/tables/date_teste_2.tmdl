	partition date_teste_2 = calculated
		mode: import
		source = ```
				
				
				    VAR DataInicio = IF(MIN(F_Vendas[data_venda])< MIN(F_Vendas[data_entrega_prevista]), MIN(F_Vendas[data_venda]), IF(MIN(F_Vendas[data_entrega_prevista]) < MIN(F_Vendas[data_entrega]), MIN(F_Vendas[data_entrega_prevista]), MIN(F_Vendas[data_entrega])))
				    VAR DataFim = IF(MAX(F_Vendas[data_entrega])>= MAX(F_Vendas[data_entrega_prevista]), MAX(F_Vendas[data_entrega]), IF(MAX(F_Vendas[data_entrega_prevista])>= MAX(F_Vendas[data_venda]), MAX(F_Vendas[data_entrega_prevista]), MAX(F_Vendas[data_venda])))
				
				RETURN
				
				ADDCOLUMNS(
				    CALENDAR(DataInicio, DataFim),
				    "Ano", YEAR([Date]),
				    "Mes_Nome", FORMAT([Date], "MMMM"),
				    "Mes_Numero", MONTH([Date]),
				    "Mes_ano", FORMAT([Date], "mm-yyyy"),
				    "Serial_mes_ano", FORMAT([Date], "yyyymm")
				
				
				)
				```

	annotation PBI_Id = bbf626caa01c42b59d02b10f20408bc6

